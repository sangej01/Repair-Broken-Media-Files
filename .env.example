# Repair Broken Media Files Configuration
# Copy this file to .env and fill in your values

# Radarr connection
RADARR_URL=http://mforum-ms01-a:8989
RADARR_API=your-api-key-here

# Email notifications (Gmail)
# Generate an app password at https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Database backend ─────────────────────────────────────────────────────────
# 'sqlite'   (default) — local repair.db, single-PC use
# 'postgres'           — shared LAN database for multi-PC distributed scanning
DB_BACKEND=sqlite

# Required when DB_BACKEND=postgres. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Tables 'repair_files' and 'repair_runs' will be auto-created.
# DATABASE_URL=postgresql://casaos:casaos@192.168.1.238:5432/casaos

# Optional: override the worker hostname used to tag DB records.
# Defaults to socket.gethostname() if not set.
# WORKER_ID=ms01-a
